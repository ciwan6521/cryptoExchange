# ============================================
# Crypto4Pro Backend — Environment Variables
# Copy to .env and fill in values
# ============================================

# App
APP_NAME=crypto4pro
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://crypto4pro:crypto4pro_password@localhost:5432/crypto4pro

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-jwt-secret-key-min-32-chars
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin JWT (separate from user JWT)
ADMIN_JWT_SECRET_KEY=change-me-admin-jwt-secret-key
ADMIN_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Wallet / Blockchain (Phase 2 — feature-flagged)
ENABLE_BLOCKCHAIN_WALLET=false
ALCHEMY_API_KEY=
TRON_API_KEY=

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
