# ============================================
# Crypto4Pro — Environment Variables
# Copy to .env.local and adjust as needed.
# All NEXT_PUBLIC_ vars are available client-side.
# ============================================

# --- Feature Flags ---
# Set to "true" or "false" to toggle features.
NEXT_PUBLIC_ENABLE_LIVE_TRADING=true
NEXT_PUBLIC_ENABLE_WITHDRAW=true
NEXT_PUBLIC_ENABLE_DEPOSIT=true
NEXT_PUBLIC_ENABLE_FUTURES=true
NEXT_PUBLIC_ENABLE_REALTIME=true
NEXT_PUBLIC_ENABLE_STOP_LIMIT=true
NEXT_PUBLIC_ENABLE_API_KEYS=true
NEXT_PUBLIC_ENABLE_3D_HERO=true
NEXT_PUBLIC_ENABLE_SOCIAL_LOGIN=false
NEXT_PUBLIC_MAINTENANCE_MODE=false

# --- T4PRO ICO / Social Links ---
NEXT_PUBLIC_T4PRO_TELEGRAM=https://t.me/crypto4pro
NEXT_PUBLIC_T4PRO_TWITTER=https://twitter.com/crypto4pro
NEXT_PUBLIC_T4PRO_INSTAGRAM=https://instagram.com/crypto4pro
NEXT_PUBLIC_T4PRO_ICO_STATUS=live
NEXT_PUBLIC_T4PRO_ICO_PRICE=0.05
NEXT_PUBLIC_T4PRO_ICO_HARD_CAP=2,500,000
NEXT_PUBLIC_T4PRO_ICO_SOFT_CAP=500,000
NEXT_PUBLIC_T4PRO_ICO_MIN_BUY=50
# NEXT_PUBLIC_T4PRO_BUY_URL=
# NEXT_PUBLIC_T4PRO_WHITEPAPER=
# NEXT_PUBLIC_T4PRO_CONTRACT_ADDRESS=0x...

# --- Convert / Platform Features ---
CONVERT_SPREAD_RATE=0.002
ENABLE_CONVERT=true
ENABLE_P2P=true
ENABLE_LAUNCHPAD=true
ENABLE_OPTIONS=true
ENABLE_REFERRAL=true

# --- OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback
OAUTH_REDIRECT_BASE=https://crypto4pro.io

# --- KYC Provider Webhook ---
KYC_WEBHOOK_SECRET=

# --- Market Maker Bot ---
MARKET_MAKER_EMAIL=mm@crypto4pro.io
SEED_MM_PASSWORD=
MARKET_MAKER_SPREAD_BPS=50
MARKET_MAKER_SIZE_USDT=100

# --- T4PRO On-Chain (BSC) ---
NEXT_PUBLIC_T4PRO_CONTRACT_ADDRESS=

# --- Backend ---
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string
DATABASE_URL=postgresql+asyncpg://crypto4pro:crypto4pro_password@localhost:5432/crypto4pro
REDIS_URL=redis://localhost:6379/0

# --- JWT Secrets (MUST be unique, random, >= 32 chars) ---
JWT_SECRET_KEY=change-me-jwt-secret-key-min-32-chars
ADMIN_JWT_SECRET_KEY=change-me-admin-jwt-secret-key

# --- Seed Admin Passwords (>= 12 chars, only used for initial seed) ---
SEED_SUPER_ADMIN_EMAIL=
SEED_SUPER_ADMIN_USERNAME=superadmin
SEED_SUPER_ADMIN_PASSWORD=
SEED_ADMIN_PASSWORD=
SEED_OPERATOR_PASSWORD=
SEED_FINANCE_PASSWORD=
SEED_VIEWER_PASSWORD=

# --- Leverage / Futures ---
ENABLE_FUTURES=true
LEVERAGE_MAX=100
LEVERAGE_MIN_MARGIN_USDT=10
LEVERAGE_MAINTENANCE_MARGIN_RATE=0.005

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000"]
ALLOWED_ORIGINS=["http://localhost:3000"]

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Withdrawal Safety ---
WITHDRAWAL_DAILY_LIMIT_USDT=50000
WITHDRAWAL_PER_TX_MAX_USDT=25000
WITHDRAWAL_MULTI_APPROVAL_THRESHOLD=10000
WITHDRAWAL_MULTI_APPROVAL_COUNT=2
WITHDRAWAL_ADDRESS_COOLDOWN_HOURS=24
WITHDRAWAL_VELOCITY_MAX_PER_HOUR=3
WITHDRAWAL_FEE_USDT=1

# --- Admin Self-Protection ---
ADMIN_LARGE_CREDIT_THRESHOLD=10000

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60
AUTH_RATE_LIMIT_PER_MINUTE=10

# --- Account Lockout ---
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# --- Alerting ---
ALERT_WEBHOOK_URL=  # Slack/Discord webhook URL (leave empty for log-only)

# --- Pay4Pro Integration (Wallet/Blockchain) ---
PAY4PRO_BASE_URL=              # e.g. https://api.pay4pro.io
PAY4PRO_PUBLIC_KEY=            # pk_xxx from Pay4Pro dashboard
PAY4PRO_SECRET_KEY=            # sk_xxx from Pay4Pro dashboard
PAY4PRO_API_KEY=               # legacy alias
PAY4PRO_WEBHOOK_SECRET=        # HMAC secret for webhook signature verification
PAY4PRO_DEFAULT_ASSET=USDT
PAY4PRO_DEFAULT_NETWORK=BSC

# --- Frontend Backend URL ---
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
